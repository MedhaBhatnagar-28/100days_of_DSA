#include <stdio.h>
#include <stdlib.h>

typedef struct Node {
    int data;
    struct Node* left;
    struct Node* right;
} Node;

Node* newNode(int val) {
    Node* node = (Node*)malloc(sizeof(Node));
    node->data = val;
    node->left = node->right = NULL;
    return node;
}

typedef struct {
    Node** arr;
    int front, rear, size;
} Queue;

Queue* createQueue(int n) {
    Queue* q = (Queue*)malloc(sizeof(Queue));
    q->arr = (Node**)malloc(sizeof(Node*) * n);
    q->front = 0;
    q->rear = 0;
    q->size = 0;
    return q;
}

void enqueue(Queue* q, Node* node) {
    q->arr[q->rear++] = node;
    q->size++;
}

Node* dequeue(Queue* q) {
    q->size--;
    return q->arr[q->front++];
}

Node* buildTree(int arr[], int n) {
    if (n == 0 || arr[0] == -1) return NULL;

    Queue* q = createQueue(n);
    Node* root = newNode(arr[0]);
    enqueue(q, root);

    int i = 1;
    while (i < n && q->size > 0) {
        Node* curr = dequeue(q);

        if (arr[i] != -1) {
            curr->left = newNode(arr[i]);
            enqueue(q, curr->left);
        }
        i++;

        if (i < n && arr[i] != -1) {
            curr->right = newNode(arr[i]);
            enqueue(q, curr->right);
        }
        i++;
    }
    return root;
}

void rightView(Node* root) {
    if (!root) return;

    Queue* q = createQueue(2000);
    enqueue(q, root);

    while (q->size > 0) {
        int size = q->size;

        for (int i = 0; i < size; i++) {
            Node* node = dequeue(q);

            if (i == size - 1)
                printf("%d ", node->data);

            if (node->left) enqueue(q, node->left);
            if (node->right) enqueue(q, node->right);
        }
    }
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for (int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    Node* root = buildTree(arr, n);
    rightView(root);

    return 0;
}
