#include <stdio.h>

#define MAX 1000

int canPaint(int arr[], int n, int k, int maxTime) {
    int painters = 1;
    int curr = 0;

    for (int i = 0; i < n; i++) {
        if (arr[i] > maxTime)
            return 0;

        if (curr + arr[i] <= maxTime) {
            curr += arr[i];
        } else {
            painters++;
            curr = arr[i];
        }

        if (painters > k)
            return 0;
    }
    return 1;
}

int main() {
    int n, k;
    scanf("%d %d", &n, &k);

    int arr[MAX];
    int sum = 0, maxVal = 0;

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        sum += arr[i];
        if (arr[i] > maxVal)
            maxVal = arr[i];
    }

    int left = maxVal, right = sum, ans = sum;

    while (left <= right) {
        int mid = (left + right) / 2;

        if (canPaint(arr, n, k, mid)) {
            ans = mid;
            right = mid - 1;
        } else {
            left = mid + 1;
        }
    }

    printf("%d", ans);

    return 0;
}
