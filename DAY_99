#include <stdio.h>
#include <stdlib.h>

#define MAX 1000

typedef struct {
    int pos;
    int speed;
} Car;

int cmp(const void *a, const void *b) {
    Car *c1 = (Car*)a;
    Car *c2 = (Car*)b;
    return c2->pos - c1->pos; // descending by position
}

int main() {
    int n, target;
    scanf("%d %d", &n, &target);

    Car cars[MAX];

    for (int i = 0; i < n; i++)
        scanf("%d", &cars[i].pos);

    for (int i = 0; i < n; i++)
        scanf("%d", &cars[i].speed);

    qsort(cars, n, sizeof(Car), cmp);

    double lastTime = -1.0;
    int fleets = 0;

    for (int i = 0; i < n; i++) {
        double time = (double)(target - cars[i].pos) / cars[i].speed;

        if (time > lastTime) {
            fleets++;
            lastTime = time;
        }
    }

    printf("%d", fleets);

    return 0;
}
