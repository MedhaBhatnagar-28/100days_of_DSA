#include <stdio.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    int maxVal = 0;

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        if (arr[i] > maxVal)
            maxVal = arr[i];
    }

    int *count = (int*)calloc(maxVal + 1, sizeof(int));
    int *output = (int*)malloc(n * sizeof(int));

    // Frequency count
    for (int i = 0; i < n; i++)
        count[arr[i]]++;

    // Prefix sum
    for (int i = 1; i <= maxVal; i++)
        count[i] += count[i - 1];

    // Build output (stable)
    for (int i = n - 1; i >= 0; i--) {
        output[count[arr[i]] - 1] = arr[i];
        count[arr[i]]--;
    }

    // Print sorted array
    for (int i = 0; i < n; i++)
        printf("%d ", output[i]);

    free(count);
    free(output);

    return 0;
}
