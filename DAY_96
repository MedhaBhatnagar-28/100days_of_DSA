#include <stdio.h>
#include <stdlib.h>

#define MAX 1000

typedef struct Node {
    float val;
    struct Node* next;
} Node;

Node* createNode(float val) {
    Node* newNode = (Node*)malloc(sizeof(Node));
    newNode->val = val;
    newNode->next = NULL;
    return newNode;
}

// Insert in sorted order (for bucket)
void insertSorted(Node** head, float val) {
    Node* newNode = createNode(val);

    if (*head == NULL || (*head)->val >= val) {
        newNode->next = *head;
        *head = newNode;
        return;
    }

    Node* temp = *head;
    while (temp->next && temp->next->val < val)
        temp = temp->next;

    newNode->next = temp->next;
    temp->next = newNode;
}

int main() {
    int n;
    scanf("%d", &n);

    float arr[MAX];
    for (int i = 0; i < n; i++)
        scanf("%f", &arr[i]);

    Node* buckets[n];
    for (int i = 0; i < n; i++)
        buckets[i] = NULL;

    // Distribute into buckets
    for (int i = 0; i < n; i++) {
        int idx = (int)(arr[i] * n);
        insertSorted(&buckets[idx], arr[i]);
    }

    // Concatenate buckets
    int k = 0;
    for (int i = 0; i < n; i++) {
        Node* temp = buckets[i];
        while (temp) {
            arr[k++] = temp->val;
            temp = temp->next;
        }
    }

    // Print sorted array
    for (int i = 0; i < n; i++)
        printf("%f ", arr[i]);

    return 0;
}
