#include <stdio.h>

#define MAX 100

int adj[MAX][MAX];
int visited[MAX];
int stack[MAX];
int top = -1;

void dfs(int u, int n) {
    visited[u] = 1;

    for (int v = 0; v < n; v++) {
        if (adj[u][v] && !visited[v]) {
            dfs(v, n);
        }
    }

    stack[++top] = u;
}

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    // Initialize
    for (int i = 0; i < n; i++) {
        visited[i] = 0;
        for (int j = 0; j < n; j++)
            adj[i][j] = 0;
    }

    // Directed edges
    for (int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
    }

    // Run DFS for all nodes
    for (int i = 0; i < n; i++) {
        if (!visited[i])
            dfs(i, n);
    }

    // Print topological order
    while (top >= 0) {
        printf("%d ", stack[top--]);
    }

    return 0;
}
