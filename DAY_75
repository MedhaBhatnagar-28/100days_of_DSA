#include <stdio.h>

#define MAX 1000

int main() {
    int n;
    scanf("%d", &n);

    int arr[MAX];
    for (int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    int prefixSum[MAX];
    int firstIndex[MAX * 2];
    
    for (int i = 0; i < MAX * 2; i++)
        firstIndex[i] = -1;

    int sum = 0, maxLen = 0;
    int offset = MAX; // to handle negative sums

    for (int i = 0; i < n; i++) {
        sum += arr[i];

        if (sum == 0)
            maxLen = i + 1;

        if (firstIndex[sum + offset] != -1) {
            int len = i - firstIndex[sum + offset];
            if (len > maxLen)
                maxLen = len;
        } else {
            firstIndex[sum + offset] = i;
        }
    }

    printf("%d", maxLen);

    return 0;
}
